# Data — raw and processed data never committed
data/raw/**
data/processed/**
data/features/**
data/models/**
!data/raw/**/.gitkeep
!data/processed/.gitkeep
!data/features/.gitkeep
!data/external/.gitkeep

# Reports (generated artefacts)
reports/**
!reports/.gitkeep
!reports/*.md

# Notebooks — exploratory/local; durable narratives should live in Quarto/docs
*.ipynb
notebooks/**
quarto/ipynb

# Docs — keep docs in git; ignore generated Quarto output/cache
docs/.quarto/
docs/quarto/_site/
docs/quarto/.quarto/
/.quarto/

# Jupyter
.ipynb_checkpoints/

# Environment
.env
*.env
config/secrets.yaml

