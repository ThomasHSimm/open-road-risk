        "#| label: exposure-helpers\n",
        "#| include: false\n",
        "\n",
        "def prepare_webtris_site_exposure(sites, webtris, exposure_columns, status_value=\"active\"):\n",
        "    required = {\"latitude\", \"longitude\", \"status\", \"site_id\"}\n",
        "    if sites.empty or not required.issubset(sites.columns):\n",
        "        return pd.DataFrame()\n",
        "    active = sites[\n",
        "        sites[\"latitude\"].notna()\n",
        "        & sites[\"longitude\"].notna()\n",
        "        & (sites[\"status\"].astype(str).str.strip().str.lower() == status_value)\n",
        "    ].copy()\n",
        "    if active.empty:\n",
        "        return pd.DataFrame()\n",
        "    exposure_columns = [c for c in exposure_columns if c in webtris.columns]\n",
        "    if not exposure_columns:\n",
        "        return pd.DataFrame()\n",
        "    site_exp = (\n",
        "        webtris.groupby(\"site_id\", dropna=False)[exposure_columns]\n",
        "        .mean()\n",
        "        .reset_index()\n",
        "    )\n",
        "    return active.merge(site_exp, on=\"site_id\", how=\"left\")\n",
        "\n",
        "\n",
        "def plot_webtris_site_exposure(active_sites, value_col, cmap=\"hot\", clim=None,\n",
        "                                title=None, colorbar_label=None, figsize=(9, 9),\n",
        "                                marker_size_range=(20, 200)):\n",
        "    if active_sites.empty or value_col not in active_sites.columns:\n",
        "        print(f\"Column {value_col} not available.\")\n",
        "        return\n",
        "    plot_sites = active_sites[active_sites[value_col].notna()].copy()\n",
        "    if plot_sites.empty:\n",
        "        print(f\"No data for {value_col}.\")\n",
        "        return\n",
        "    vals = plot_sites[value_col]\n",
        "    smin, smax = marker_size_range\n",
        "    size_scaled = smin + (smax - smin) * (vals - vals.min()) / (vals.max() - vals.min() + 1e-9)\n",
        "    vmin, vmax = (None, None) if clim is None else clim\n",
        "\n",
        "    sites_gdf = gpd.GeoDataFrame(\n",
        "        plot_sites,\n",
        "        geometry=gpd.points_from_xy(plot_sites[\"longitude\"], plot_sites[\"latitude\"]),\n",
        "        crs=\"EPSG:4326\",\n",
        "    ).to_crs(epsg=3857)\n",
        "    minx, miny, maxx, maxy = sites_gdf.total_bounds\n",
        "    pad = max(maxx - minx, maxy - miny) * 0.08\n",
        "\n",
        "    fig, ax = plt.subplots(figsize=figsize)\n",
        "    ax.set_xlim(minx - pad, maxx + pad)\n",
        "    ax.set_ylim(miny - pad, maxy + pad)\n",
        "    try:\n",
        "        cx.add_basemap(ax, source=cx.providers.OpenStreetMap.Mapnik,\n",
        "                       zoom=\"auto\", attribution_size=6)\n",
        "    except Exception as exc:\n",
        "        print(f\"Basemap unavailable: {exc}\")\n",
        "    sites_gdf.plot(ax=ax, column=value_col, cmap=cmap, vmin=vmin, vmax=vmax,\n",
        "                   markersize=size_scaled, edgecolor=\"white\", linewidth=0.35,\n",
        "                   alpha=0.9, legend=True, zorder=3)\n",
        "    ax.set_axis_off()\n",
        "    ax.set_title(title or f\"WebTRIS — mean {value_col}\")\n",
        "    plt.tight_layout()\n",
        "    plt.show()"
      ],
      "id": "exposure-helpers",
      "execution_count": null,
      "outputs": []
