        "#| label: time-webtris-prep\n",
        "#| include: false\n",
        "\n",
        "nums = [12, 16, 18, 24]\n",
        "\n",
        "for val_type in [\"adt\", \"awt\"]:\n",
        "    for num in nums:\n",
        "        col_hour = f\"{val_type}{num}hour\"\n",
        "        col_lv   = f\"{val_type}{num}largevehiclepercentage\"\n",
        "        if col_hour in time_webtris.columns:\n",
        "            time_webtris[col_hour] = pd.to_numeric(time_webtris[col_hour], errors=\"coerce\")\n",
        "        if col_lv in time_webtris.columns:\n",
        "            time_webtris[col_lv] = pd.to_numeric(time_webtris[col_lv], errors=\"coerce\")\n",
        "        if col_hour in time_webtris.columns and col_lv in time_webtris.columns:\n",
        "            time_webtris[f\"{col_hour}_hgv\"] = (\n",
        "                time_webtris[col_hour] * time_webtris[col_lv] / 100\n",
        "            )\n",
        "\n",
        "cols_base = [\"adtNUMhour\", \"awtNUMhour\", \"adtNUMhour_hgv\", \"awtNUMhour_hgv\"]\n",
        "for col in cols_base:\n",
        "    base_24 = col.replace(\"NUM\", \"24\")\n",
        "    time_webtris[base_24] = pd.to_numeric(time_webtris[base_24], errors=\"coerce\")\n",
        "    for num in nums:\n",
        "        num_col  = col.replace(\"NUM\", str(num))\n",
        "        frac_col = f\"frac_{num_col}\"\n",
        "        time_webtris[num_col]  = pd.to_numeric(time_webtris[num_col], errors=\"coerce\")\n",
        "        time_webtris[frac_col] = time_webtris[num_col] / time_webtris[base_24]\n",
        "\n",
        "frac_cols = [c for c in time_webtris.columns if c.startswith(\"frac_\")]"
